# Example production environment for a private single-install deployment.
# Copy this to .env and replace the secret values before first run.

TRADEDESK_ENVIRONMENT=production
TRADEDESK_DEBUG=false
TRADEDESK_ENFORCE_STARTUP_CHECKS=true

TRADEDESK_JWT_SECRET_KEY=replace-with-strong-random-secret
TRADEDESK_BCRYPT_ROUNDS=12

TRADEDESK_DIAGNOSTICS_ENABLED=true
TRADEDESK_DIAGNOSTICS_ADMIN_KEY=replace-with-strong-random-secret
TRADEDESK_DIAGNOSTICS_NONCES_DIR=C:/Users/sirtv/TradeDesk/diagnostics/nonces
TRADEDESK_DIAGNOSTICS_STORAGE_DIR=C:/Users/sirtv/TradeDesk/diagnostics

# Optional: set these only if you want diagnostics email alerts.
# TRADEDESK_DIAGNOSTICS_NOTIFY_VIA_EMAIL=false
# TRADEDESK_DIAGNOSTICS_SMTP_HOST=
# TRADEDESK_DIAGNOSTICS_SMTP_PORT=587
# TRADEDESK_DIAGNOSTICS_SMTP_USER=
# TRADEDESK_DIAGNOSTICS_SMTP_PASSWORD=

# Optional Sentry DSN.
# TRADEDESK_SENTRY_DSN=
## Production environment variables for TradeDesk
# Copy this to .env (or configure your environment/CI secrets) and replace placeholder values.

TRADEDESK_ENVIRONMENT=production
TRADEDESK_DEBUG=false
TRADEDESK_ENFORCE_STARTUP_CHECKS=true

# Paths (override for custom locations)
TRADEDESK_BASE_DIR=C:/TradeDesk
TRADEDESK_DATA_DIR=C:/TradeDesk/data
TRADEDESK_BACKUP_DIR=C:/TradeDesk/backups
TRADEDESK_LOGS_DIR=C:/TradeDesk/logs
TRADEDESK_DB_FILE_NAME=tradedesk.db

# SECURITY: set a strong secret (32+ random bytes base64). Example generator (PowerShell):
# $b = New-Object byte[] 32; (New-Object System.Security.Cryptography.RNGCryptoServiceProvider).GetBytes($b); [Convert]::ToBase64String($b)
TRADEDESK_JWT_SECRET_KEY=replace-with-strong-random-secret
TRADEDESK_JWT_ALGORITHM=HS256
TRADEDESK_ACCESS_TOKEN_EXPIRE_MINUTES=480
TRADEDESK_REFRESH_TOKEN_EXPIRE_DAYS=7

TRADEDESK_BCRYPT_ROUNDS=12
TRADEDESK_FAILED_LOGIN_LIMIT=5
TRADEDESK_LOCK_MINUTES=15

# Diagnostics (error-report uploads)
# If you plan to accept user-uploaded diagnostics, set these appropriately.
TRADEDESK_DIAGNOSTICS_ENABLED=true
# If true, clients may self-register to receive an install secret for signed uploads
TRADEDESK_DIAGNOSTICS_ALLOW_SELF_REGISTER=true
# Optional admin key to authorize registrations (set to a random secret for extra control)
TRADEDESK_DIAGNOSTICS_ADMIN_KEY=
TRADEDESK_DIAGNOSTICS_STORAGE_DIR=C:/TradeDesk/diagnostics
TRADEDESK_DIAGNOSTICS_MAX_BYTES=5242880

# Optional: diagnostics upload URL for desktop clients (set in client environment or installer)
# Example: https://ops.example.com/diagnostics/upload
TRADEDESK_DIAGNOSTICS_UPLOAD_URL=
# Optional local upload URL used by packaged desktop clients when different from public URL
TRADEDESK_DIAGNOSTICS_UPLOAD_URL_LOCAL=

# Optional webhook: a server-side URL that will receive a JSON POST on each new upload
TRADEDESK_DIAGNOSTICS_WEBHOOK_URL=

# Signature validation skew (seconds). Clients must sign with a timestamp within this window.
TRADEDESK_DIAGNOSTICS_SIGNATURE_SKEW_SECONDS=300

# Nonce persistence directory (optional). If empty, uses diagnostics storage/nonces
TRADEDESK_DIAGNOSTICS_NONCES_DIR=

# Email notification settings (optional)
TRADEDESK_DIAGNOSTICS_NOTIFY_VIA_EMAIL=false
TRADEDESK_DIAGNOSTICS_NOTIFY_EMAIL_FROM=ops@example.com
TRADEDESK_DIAGNOSTICS_NOTIFY_EMAIL_TO=ops+diagnostics@example.com
TRADEDESK_DIAGNOSTICS_SMTP_HOST=
TRADEDESK_DIAGNOSTICS_SMTP_PORT=587
TRADEDESK_DIAGNOSTICS_SMTP_USER=
TRADEDESK_DIAGNOSTICS_SMTP_PASSWORD=

# Optional Sentry DSN (leave blank if not using Sentry)
TRADEDESK_SENTRY_DSN=
